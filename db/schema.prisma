// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --------------------------------------

model User {
  id               Int       @id @default(autoincrement())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  email            String    @unique
  hashedPassword   String?
  role             String    @default("USER")
  isAdmin          Boolean   @default(false)
  isShopMode       Boolean   @default(false)
  isShopRegistered Boolean   @default(false)
  profileImage     String?
  emailVerified    Boolean   @default(false)
  tokens           Token[]
  sessions         Session[]

  personalInfo  PersonalInfo?
  shop          Shop?
  cartItems     CartItem[]
  rents         Rent[]
  reviews       Review[]
  reports       Report[]
  shopReports   ReportShop[]
  addresses     Address[]
  notifications Notification[]
}

model Shop {
  id              Int          @id @default(autoincrement())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          Int          @unique
  shopName        String
  email           String
  street          String
  barangay        String
  city            String
  province        String
  country         String
  zipCode         String
  contact         String
  status          String       @default("pending")
  description     String?
  imageProfile    String?
  imageBg         String?
  documentDTI     String?
  dtiStatus       String       @default("pending")
  dtiNotes        String?
  documentPermit  String?
  permitStatus    String       @default("pending")
  permitNotes     String?
  documentTax     String?
  taxStatus       String       @default("pending")
  taxNotes        String?
  linkFacebook    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  products        Product[]
  reports         ReportShop[]
  rejectionReason String?
}

model PersonalInfo {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  firstName   String
  lastName    String
  middleName  String?
  birthDate   DateTime
  phoneNumber String?
  street      String
  barangay    String
  city        String
  province    String
  country     String
  zipCode     String
  userId      Int      @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id                 Int       @id @default(autoincrement())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  expiresAt          DateTime?
  handle             String    @unique
  hashedSessionToken String?
  antiCSRFToken      String?
  publicData         String?
  privateData        String?

  user   User? @relation(fields: [userId], references: [id])
  userId Int?
}

model Token {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hashedToken String
  type        String
  // See note below about TokenType enum
  // type        TokenType
  expiresAt   DateTime
  sentTo      String

  user   User @relation(fields: [userId], references: [id])
  userId Int

  @@unique([hashedToken, type])
}

// NOTE: It's highly recommended to use an enum for the token type
//       but enums only work in Postgres.
//       See: https://blitzjs.com/docs/database-overview#switch-to-postgre-sql
// enum TokenType {
//   RESET_PASSWORD
// }

model Product {
  id             Int              @id @default(autoincrement())
  shop           Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId         Int
  name           String
  description    String?
  status         String           @default("active")
  deliveryOption String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  variants       ProductVariant[] // Relationship with ProductVariant
  images         ProductImage[]
  category       Category         @relation("ProductCategories", fields: [categoryid], references: [id])
  categoryid     Int
  cartItems      CartItem[]
  reviews        Review[]
  reports        Report[]
}

model DamagePolicies {
  id                    Int            @id @default(autoincrement())
  productVariantId      Int
  productVariant        ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  damageSeverity        String // "MINOR", "MODERATE", "MAJOR", "TOTAL_LOSS"
  damageSeverityPercent Float // Override for this specific item
  description           String?
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int

  // The "Anchor" fields for depreciation
  originalMSRP         Float    @default(0)
  originalPurchaseDate DateTime @default(now())
  condition            String   @default("New")

  quantity Int // Stock
  price    Float // Rental Price per Day

  damagePolicies DamagePolicies[]
  rentItems      RentItem[]
  attributes     ProductVariantAttribute[]
  cartItems      CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id               Int             @id @default(autoincrement())
  productId        Int
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  url              String
  attributeValueId Int?
  attributeValue   AttributeValue? @relation(fields: [attributeValueId], references: [id])
}

model Category {
  id      Int    @id @default(autoincrement())
  name    String
  slug    String @unique
  iconKey String @default("default")

  // Platform-wide defaults for this category
  annualDepreciationRate Float @default(0.10) // e.g., 0.10 = 10%
  minimumValuePercent    Float @default(0.05) // Item never worth less than 5%
  defaultMinorPercent    Float @default(0.15) // 15% of current value
  defaultModeratePercent Float @default(0.30) // 30% of current value
  defaultMajorPercent    Float @default(0.60) // 60% of current value

  products  Product[] @relation("ProductCategories")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CartItem {
  id             Int            @id @default(autoincrement())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int // Foreign key to User
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId      Int // Foreign key to Product
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId      Int // Foreign key to ProductVariant
  quantity       Int            @default(1) // Quantity of the product in the cart
  deliveryMethod String
  startDate      DateTime? // Optional rental start date
  endDate        DateTime? // Optional rental end date
}

model Attribute {
  id     Int              @id @default(autoincrement())
  name   String           @unique // e.g., "Color", "Size", "Material"
  values AttributeValue[]
}

model AttributeValue {
  id          Int       @id @default(autoincrement())
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String // e.g., "Red", "Large", "Cotton"
  hexCode     String? // Optional: for colors

  variantAttributes ProductVariantAttribute[]
  images            ProductImage[]

  @@unique([attributeId, value])
}

model ProductVariantAttribute {
  productVariantId Int
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  attributeValueId Int
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([productVariantId, attributeValueId])
}

model Rent {
  id              Int        @id @default(autoincrement())
  userId          Int
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalPrice      Float
  status          String // "PENDING", "ACTIVE", "RETURNED", "CANCELLED"
  deliveryAddress String
  items           RentItem[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model RentItem {
  id               Int            @id @default(autoincrement())
  rentId           Int
  rent             Rent           @relation(fields: [rentId], references: [id], onDelete: Cascade)
  productVariantId Int
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int
  price            Float
  status           String // "RENTING", "RETURNED", "DAMAGED"
  deliveryMethod   String
  note             String?
  startDate        DateTime
  endDate          DateTime

  returnedDamagedQty Int       @default(0)
  charges            Charge[]
  payments           Payment[]
  reviews            Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Charge {
  id         Int      @id @default(autoincrement())
  rentItemId Int
  rentItem   RentItem @relation(fields: [rentItemId], references: [id])
  type       String // "DAMAGED", "LATE"

  // Details for calculation
  severity                 String? // "MINOR", "MODERATE", "MAJOR", "TOTAL_LOSS"
  depreciatedValueAtDamage Float? // Snapshot of item value when broken

  amount Float // Final calculated fee
  status String @default("UNPAID") // "UNPAID", "PAID"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id         Int      @id @default(autoincrement())
  rentItemId Int
  rentItem   RentItem @relation(fields: [rentItemId], references: [id])
  amount     Float // Payment amount
  status     String // "PENDING", "COMPLETED", "FAILED"
  penaltyFee Float?
  createdAt  DateTime @default(now())
}

// Review Model
model Review {
  id          Int      @id @default(autoincrement())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   Int // Foreign key to Product
  user        User     @relation(fields: [userId], references: [id]) // Optional relation to User
  userId      Int // Foreign key to User (optional)
  rentItem    RentItem @relation(fields: [rentItemId], references: [id], onDelete: Cascade)
  rentItemId  Int // Foreign key to RentItem
  rating      Int // Rating (e.g., 1 to 5 stars)
  comment     String? // Optional comment
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Report Model
model Report {
  id          Int      @id @default(autoincrement())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   Int // Foreign key to Product
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  reason      String // Reason for the report
  description String? // Detailed description of the issue
  status      String   @default("pending") // Status of the report (e.g., 'pending', 'resolved', 'rejected')
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Report Shop Model
model ReportShop {
  id          Int      @id @default(autoincrement())
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId      Int
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  reason      String // Reason for the report
  description String? // Detailed description of the issue
  status      String   @default("pending") // Status of the report (e.g., 'pending', 'resolved', 'rejected')
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

//Barangay Model
model Barangay {
  id      Int    @id @default(autoincrement())
  name    String @unique
  city    String @default("Legazpi City")
  zipCode String @default("4500")
}

model Address {
  id        Int     @id @default(autoincrement())
  street    String
  barangay  String
  city      String  @default("Legazpi City")
  province  String  @default("Albay")
  country   String  @default("Philippines")
  zipCode   String  @default("4500")
  isDefault Boolean @default(false)
  userId    Int
  user      User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Optional: Map to specific table name if required
  // @@map("add_address")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
