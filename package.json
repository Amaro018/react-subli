{
  "name": "subli-react",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "blitz dev",
    "build": "blitz build",
    "start": "blitz start",
    "studio": "blitz prisma studio",
    "lint": "eslint --ignore-path .gitignore --ext .js,.ts,.tsx .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepare": "husky install",
    "prisma:generate": "npx prisma generate --schema=db/schema.prisma",
    "db:seed": "node db/seedsRunner.cjs"
  },
  "prisma": {
    "schema": "db/schema.prisma"
  },
  "prettier": {
    "semi": false,
    "printWidth": 100
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --cache --fix"
    ]
  },
  "dependencies": {
    "@blitzjs/auth": "2.1.3",
    "@blitzjs/next": "2.1.3",
    "@blitzjs/rpc": "2.1.3",
    "@emotion/react": "11.13.3",
    "@emotion/styled": "11.13.0",
    "@fullcalendar/core": "6.1.15",
    "@fullcalendar/daygrid": "6.1.15",
    "@fullcalendar/react": "6.1.15",
    "@mui/icons-material": "6.1.9",
    "@mui/material": "6.1.7",
    "@mui/x-charts": "7.23.2",
    "@mui/x-date-pickers": "7.23.0",
    "@mui/x-date-pickers-pro": "7.23.0",
    "@nextui-org/date-picker": "2.1.8",
    "@nextui-org/system": "2.2.6",
    "@nextui-org/theme": "2.2.11",
    "@prisma/client": "5.4.2",
    "blitz": "2.1.3",
    "dayjs": "1.11.13",
    "formik": "2.4.6",
    "framer-motion": "11.12.0",
    "lucide-react": "0.539.0",
    "next": "^14.2.24",
    "nodemailer": "^6.10.0",
    "prisma": "5.4.2",
    "react": "18.2.0",
    "react-confetti": "6.4.0",
    "react-dom": "18.2.0",
    "secure-password": "4.0.0",
    "sonner": "2.0.1",
    "sweetalert2": "^11.17.2",
    "swiper": "^11.2.0",
    "yup": "1.4.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@next/env": "13.4.19",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "13.4.0",
    "@testing-library/react-hooks": "8.0.1",
    "@types/node": "18.11.9",
    "@types/preview-email": "2.0.1",
    "@types/react": "18.0.25",
    "@typescript-eslint/eslint-plugin": "5.42.1",
    "@vitejs/plugin-react": "2.2.0",
    "ajv": "^8.18.0",
    "autoprefixer": "10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.24",
    "eslint-config-prettier": "8.5.0",
    "husky": "8.0.2",
    "jsdom": "20.0.3",
    "lint-staged": "13.0.3",
    "postcss": "8.4.49",
    "prettier": "^2.7.1",
    "prettier-plugin-prisma": "4.4.0",
    "pretty-quick": "3.1.3",
    "preview-email": "3.0.7",
    "tailwindcss": "3.4.15",
