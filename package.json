    "cross-spawn": "^7.0.6",
    "diff": "^5.2.2",
    "glob": "^11.0.0",
    "nanoid": "^3.3.8",
    "node-fetch": "^3.3.2",
    "on-headers": "^1.1.0",
    "semver": "^7.6.3",
    "tar": "^7.4.3",
    "rimraf": "^6.0.1"
  }
